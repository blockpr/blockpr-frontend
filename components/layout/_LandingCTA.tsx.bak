{/* Left: CTA — guardado para uso futuro */}
<div className="flex-1 flex flex-col gap-6">
  <h1 className="text-[clamp(34px,4.5vw,60px)] font-bold tracking-[-0.03em] leading-[1.05] text-white">
    Certificados Digitales<br />Inmutables.
  </h1>
  <p className="text-[15px] text-white/40 leading-relaxed max-w-[440px]">
    Certificación digital en blockchain. Registramos información de forma inmutable y verificable para garantizar autenticidad, transparencia y trazabilidad.
  </p>
  <div className="flex flex-col gap-2.5">
    {[
      'Hash SHA-256 + Merkle Tree en Solana',
      'Verificación pública sin cuenta',
      'API para integrar en tu plataforma',
    ].map(f => (
      <div key={f} className="flex items-center gap-2.5 text-[13px] text-white/50">
        <span className="w-[18px] h-[18px] rounded-[4px] bg-white/7 border border-white/12 flex items-center justify-center shrink-0">
          <svg width="10" height="10" fill="none" viewBox="0 0 24 24" stroke="white" strokeWidth={2.5}>
            <path strokeLinecap="round" strokeLinejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
          </svg>
        </span>
        {f}
      </div>
    ))}
  </div>
  <div className="flex items-center gap-3 mt-2">
    <Link
      href="/signup"
      className="flex items-center gap-2 px-6 py-3 rounded-[6px] bg-white text-black text-[14px] font-medium hover:bg-white/88 transition-colors"
    >
      Empezar ahora
      <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" strokeWidth={2}>
        <path strokeLinecap="round" strokeLinejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
      </svg>
    </Link>
    <Link
      href="/login"
      className="px-5 py-3 rounded-[6px] text-[14px] font-medium text-white/55 border border-white/15 hover:text-white hover:border-white/35 transition-colors"
    >
      ¿Cómo funciona?
    </Link>
  </div>
</div>
